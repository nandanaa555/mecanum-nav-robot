       KEY CHANGES vs broken version:
         1. Collision is SPHERE (not cylinder).
              Sphere + anisotropic fdir1 is the correct gz-sim mecanum
              physics model. Cylinder without working fdir1 behaves like
              a normal rubber tyre — no strafing possible.

         2. fdir1 uses gz:expressed_in="base_footprint".
              Without this attribute gz-sim does NOT know which frame the
              direction vector is in, so anisotropic friction is applied
              inconsistently and strafe produces rotation instead.

         3. fdir1 vectors are diagonal (±45°) to encode the actual roller
              angle of mecanum wheels:
                FL / RR  →  "1 -1 0"  (rollers at -45°)
                FR / RL  →  "1  1 0"  (rollers at +45°)

         4. mu2=0.0 (not 0.01). Fully free lateral sliding.

         5. Friction block lives in <gazebo reference="wheel"><collision>
              <surface> — NOT inside the URDF <link><collision>.
              gz-sim reads the gazebo-namespaced block; the URDF-side
              <surface> tag is ignored by the physics engine.

       Visual offsets (vis_x/y/z) and c_y offset kept exactly as original
       — visual positions and mesh/collision separation are correct.
  ═══════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="wheel" params="name mesh vis_x vis_y vis_z c_x c_y c_z
                                     joint_name jx jy jz">
    <link name="${name}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${wheel_mass}"/>
        <inertia ixx="${w_ixx}" iyy="${w_iyy}" izz="${w_izz}"
                 ixy="0.0"      iyz="0.0"       ixz="0.0"/>
      </inertial>

      <visual>
        <origin xyz="${vis_x} ${vis_y} ${vis_z}" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find robo_desc)/meshes/${mesh}"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="white"/>
      </visual>

      <!--
        SPHERE collision — same approach as the working reference.
        Sphere + anisotropic fdir1 (in gazebo tag below) = correct mecanum.
        c_y offset kept to avoid mesh/collision overlap.
      -->
      <collision>
        <origin xyz="${c_x} ${c_y} ${c_z}" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${wheel_radius}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${joint_name}" type="continuous">
      <origin xyz="${jx} ${jy} ${jz}" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child  link="${name}"/>
      <axis   xyz="0.0 -1.0 0.0"/>
      <dynamics damping="0.01" friction="0.0"/>
    </joint>
  </xacro:macro>

  <!-- ─── Wheel instances ───────────────────────────────────────────── -->
  <xacro:wheel
    name="right_front"   mesh="right_front.stl"
    vis_x=" 0.083355"    vis_y="-0.102054"   vis_z="-0.0439222"
    c_x="0.0"    c_y="0.008"   c_z="0"
    joint_name="right_f"
    jx="-0.083355"       jy=" 0.102054"      jz="0.0439222"/>

  <xacro:wheel
    name="right_back"    mesh="rigth_back.stl"
    vis_x="-0.068055"    vis_y="-0.102054"   vis_z="-0.0439222"
    c_x="0.0"    c_y="0.008"   c_z="0"
    joint_name="right_b"
    jx=" 0.068055"       jy=" 0.102054"      jz="0.0439222"/>

  <xacro:wheel
    name="left_front"    mesh="left_front.stl"
    vis_x=" 0.083355"    vis_y=" 0.102054"   vis_z="-0.0439222"
    c_x="0.0"    c_y="-0.008"   c_z="0"
    joint_name="left_f"
    jx="-0.083355"       jy="-0.102054"      jz="0.0439222"/>

  <xacro:wheel
    name="left_back"     mesh="left_back.stl"
    vis_x="-0.068055"    vis_y=" 0.102054"   vis_z="-0.0439222"
    c_x="0.0"    c_y="-0.008"   c_z="0"
    joint_name="left_b"
    jx=" 0.068055"       jy="-0.102054"      jz="0.0439222"/>

  <!-- ═══════════════════════════════════════════════════════════════════
       MECANUM FRICTION — per wheel, in gazebo reference block
       ─────────────────────────────────────────────────────────────────
       fdir1 encodes the 45° roller angle for each wheel position:
         right_front (= plugin's back_right)  → rollers at -45° → "1 -1 0"
         right_back  (= plugin's front_right) → rollers at +45° → "1  1 0"
         left_front  (= plugin's back_left)   → rollers at +45° → "1  1 0"
         left_back   (= plugin's front_left)  → rollers at -45° → "1 -1 0"

       gz:expressed_in="base_footprint" is MANDATORY — tells gz-sim which
       frame the direction vector is defined in. Without it the attribute
       is silently misinterpreted and strafing produces unwanted yaw.

       mu  = 1.5  (high grip along roller direction)
       mu2 = 0.0  (zero resistance perpendicular = free roller)
  ═══════════════════════════════════════════════════════════════════ -->
  <gazebo reference="right_front">
    <material>Gazebo/White</material>
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.5</mu>
            <mu2>0.0</mu2>
            <fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="right_back">
    <material>Gazebo/White</material>
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.5</mu>
            <mu2>0.0</mu2>
            <fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="left_front">
    <material>Gazebo/White</material>
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.5</mu>
            <mu2>0.0</mu2>
            <fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="left_back">
    <material>Gazebo/White</material>
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.5</mu>
            <mu2>0.0</mu2>
            <fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════════════
       BODY PARTS
  ═══════════════════════════════════════════════════════════════════ -->
  <link name="part2">
    <inertial>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <mass value="0.296"/>
      <inertia ixx="5.2e-05" iyy="5.2e-05" izz="5.9e-05"
               ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find robo_desc)/meshes/extra.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find robo_desc)/meshes/extra.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <joint name="sensors_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="part2"/>
  </joint>

  <link name="lcd">
    <inertial>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="1e-05" iyy="1e-05" izz="1e-05"
               ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find robo_desc)/meshes/led.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find robo_desc)/meshes/led.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <joint name="display_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="lcd"/>
  </joint>

  <link name="push_button">
    <inertial>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="1e-05" iyy="1e-05" izz="1e-05"
               ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find robo_desc)/meshes/switch.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find robo_desc)/meshes/switch.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <joint name="button_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="push_button"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════════
       LIDAR LINK
  ═══════════════════════════════════════════════════════════════════ -->
  <link name="lidar">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.200"/>
      <inertia ixx="5.2e-05" iyy="5.2e-05" izz="5.9e-05"
               ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0.079 0.013 -0.133" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find robo_desc)/meshes/lidar.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find robo_desc)/meshes/lidar.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <origin xyz="-0.079 0.0 0.133" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="lidar"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════════
       IMU LINK
  ═══════════════════════════════════════════════════════════════════ -->
  <link name="imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6"
               ixy="0.0"  iyz="0.0"  ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.02 0.01"/></geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.02 0.01"/></geometry>
    </collision>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="imu_link"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════════
       GAZEBO PLUGINS
  ═══════════════════════════════════════════════════════════════════ -->

  <!-- Mecanum Drive -->
  <gazebo>
    <plugin filename="gz-sim-mecanum-drive-system"
            name="gz::sim::systems::MecanumDrive">

      <!-- Swapped order because robot is rotated 180 deg in base_footprint -->
      <front_left_joint>right_b</front_left_joint>
      <front_right_joint>left_b</front_right_joint>
      <back_left_joint>right_f</back_left_joint>
      <back_right_joint>left_f</back_right_joint>

      <wheel_separation>0.204108</wheel_separation>
      <wheelbase>0.151410</wheelbase>
      <wheel_radius>${wheel_radius}</wheel_radius>

      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>

      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>

      <odom_publish_frequency>50</odom_publish_frequency>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <min_velocity>-2.0</min_velocity>
      <max_velocity>2.0</max_velocity>
      <min_acceleration>-5.0</min_acceleration>
      <max_acceleration>5.0</max_acceleration>
    </plugin>
  </gazebo>

  <!-- Joint State Publisher -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>right_f</joint_name>
      <joint_name>right_b</joint_name>
      <joint_name>left_f</joint_name>
      <joint_name>left_b</joint_name>
      <topic>joint_states</topic>
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>

  <!-- 2-D LiDAR -->
  <gazebo reference="lidar">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle> 3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <gz_frame_id>lidar</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- IMU -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <pose>0 0 0 0 0 0</pose>
      <topic>imu</topic>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></z>
        </linear_acceleration>
      </imu>
      <always_on>true</always_on>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- Remaining material-only gazebo tags -->
  <gazebo reference="base_link">   <material>Gazebo/DarkGrey</material> </gazebo>
  <gazebo reference="lidar">       <material>Gazebo/Grey</material>     </gazebo>
  <gazebo reference="imu_link">    <material>Gazebo/Red</material>      </gazebo>
  <gazebo reference="lcd">         <material>Gazebo/White</material>    </gazebo>
  <gazebo reference="push_button"> <material>Gazebo/Red</material>      </gazebo>
  <gazebo reference="part2">       <material>Gazebo/Grey</material>     </gazebo>

</robot>

    <plugin filename="gz-sim-mecanum-drive-system"
            name="gz::sim::systems::MecanumDrive">
      <front_left_joint>front_left_joint</front_left_joint>
      <front_right_joint>front_right_joint</front_right_joint>
      <back_left_joint>rear_left_joint</back_left_joint>
      <back_right_joint>rear_right_joint</back_right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheelbase>${wheelbase}</wheelbase>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <min_velocity>-2.0</min_velocity>
      <max_velocity>2.0</max_velocity>
      <min_acceleration>-5.0</min_acceleration>
      <max_acceleration>5.0</max_acceleration>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>front_left_joint</joint_name>
      <joint_name>front_right_joint</joint_name>
      <joint_name>rear_left_joint</joint_name>
      <joint_name>rear_right_joint</joint_name>
      <topic>joint_states</topic>
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>

  <!-- 2-D LiDAR sensor -->
  <gazebo reference="lidar_link">
    <material>Gazebo/Grey</material>
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle> 3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <gz_frame_id>lidar_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- IMU sensor -->
  <gazebo reference="imu_link">
    <material>Gazebo/Red</material>
    <sensor name="imu_sensor" type="imu">
      <pose>0 0 0 0 0 0</pose>
      <topic>imu</topic>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></z>
        </linear_acceleration>
      </imu>
      <always_on>true</always_on>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <gazebo reference="base_link"><material>Gazebo/Blue</material></gazebo>

</robot>

<!-- ═══════════════════════════════════════════════════════════════════ BASE LINK ═══════════════════════════════════════════════════════════════════ -->

<link name="base_link"> <inertial> <origin xyz="0 0 0" rpy="0 0 0"/> <mass value="${base_mass}"/> <inertia ixx="0.03311" iyy="0.019021" izz="0.0495" ixy="0.0" iyz="0.0" ixz="0.0"/> </inertial> <visual> <origin xyz="0 0 0" rpy="0 0 3.14159"/> <geometry> <mesh filename="file://$(find robo_desc)/meshes/base_link2.stl" scale="0.001 0.001 0.001"/> </geometry> <material name="black"/> </visual> <!-- Base collision — box only, no mesh Mesh on base_link causes trimesh-trimesh contact with wheel cylinders --> <collision> <origin xyz="0 0 0.06" rpy="0 0 0"/> <geometry> <box size="0.20 0.18 0.06"/> </geometry> </collision> </link>

<!-- ═══════════════════════════════════════════════════════════════════ WHEEL MACRO ───────────────────────────────────────────────────────────────── FIX: <surface> friction is now INSIDE <collision>. This is the correct way in Gazebo Sim (Harmonic / gz-sim). The old <gazebo reference="wheel"><mu1>...<mu2>...<fdir1> tags are Gazebo Classic (ODE) only and are silently ignored by gz-sim — which is why strafing was broken. c_y offset on collision origin is intentional — keeps cylinder collision from coinciding with the visual mesh geometry. MECANUM FRICTION: mu = 1.0 → high grip in wheel roll direction (forward/back) mu2 = 0.01 → near-zero lateral → simulates free rollers → strafe fdir1 = "1 0 0 0 0 0" → mu acts along X (the forward/roll axis) 6-element form required by Gazebo Sim SDF surface parser ═══════════════════════════════════════════════════════════════════ -->

<xacro name="wheel" params="name mesh vis_x vis_y vis_z c_x c_y c_z fdir_x
joint_name jx jy jz">
<link name="${name}">
<inertial>
<origin xyz="0 0 0" rpy="0 0 0"/>
<mass value="${wheel_mass}"/>
<inertia ixx="${w_ixx}" iyy="${w_iyy}" izz="${w_izz}" ixy="0.0" iyz="0.0" ixz="0.0"/>
</inertial>

  <!-- Keep mesh for visual only — looks correct -->
  <visual>
    <origin xyz="${vis_x} ${vis_y} ${vis_z}" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find robo_desc)/meshes/${mesh}"
            scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="white"/>
  </visual>

  <!--
    CYLINDER collision with SURFACE friction — NOT mesh, NOT old gazebo tags.

    <surface> inside <collision> is the gz-sim way to set anisotropic friction.
    Without this, gz-sim treats all wheels as isotropic (mu=mu2) and strafing
    produces unwanted rotation instead of lateral motion.

    c_y offset kept intentionally to prevent collision/mesh overlap.
    rpy="1.5708 0 0" aligns cylinder flat face with the Y spin axis.
  -->
  <collision>
    <origin xyz="${c_x} ${c_y} ${c_z}" rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
    </geometry>
    <surface>
      <friction>
        <ode>
          <mu>5</mu>
          <mu2>0.05</mu2>
          <!-- 6-element fdir1 required by Gazebo Sim SDF surface parser -->
          <fdir1>${fdir_x} 0 0 </fdir1>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>1000000.0</kp>
          <kd>100.0</kd>
          <min_depth>0.001</min_depth>
          <max_vel>0.1</max_vel>
        </ode>
      </contact>
    </surface>
  </collision>
</link>

<joint name="${joint_name}" type="continuous">
  <origin xyz="${jx} ${jy} ${jz}" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child  link="${name}"/>
  <axis   xyz="0.0 1.0 0.0"/>
  <dynamics damping="0.01" friction="0.0"/>
</joint>

</xacro>

<!-- ─── Wheel instances ───────────────────────────────────────────── -->

<xacro
name="right_front" mesh="right_front.stl"
vis_x=" 0.083355" vis_y="-0.102054" vis_z="-0.0439222"
c_x="0.0" c_y="0.008" c_z="0"
fdir_x="1"
joint_name="right_f"
jx="-0.083355" jy=" 0.102054" jz="0.0439222"/>

<xacro
name="right_back" mesh="rigth_back.stl"
vis_x="-0.068055" vis_y="-0.102054" vis_z="-0.0439222"
c_x="0.0" c_y="0.008" c_z="0"
fdir_x="-1"
joint_name="right_b"
jx=" 0.068055" jy=" 0.102054" jz="0.0439222"/>

<xacro
name="left_front" mesh="left_front.stl"
vis_x=" 0.083355" vis_y=" 0.102054" vis_z="-0.0439222"
c_x="0.0" c_y="-0.008" c_z="0"
fdir_x="-1"
joint_name="left_f"
jx="-0.083355" jy="-0.102054" jz="0.0439222"/>

<xacro
name="left_back" mesh="left_back.stl"
vis_x="-0.068055" vis_y=" 0.102054" vis_z="-0.0439222"
c_x="0.0" c_y="-0.008" c_z="0"
fdir_x="1"
joint_name="left_b"
jx=" 0.068055" jy="-0.102054" jz="0.0439222"/>

<!-- ═══════════════════════════════════════════════════════════════════ BODY PARTS ═══════════════════════════════════════════════════════════════════ -->

<link name="part2"> <inertial> <origin xyz="0 0 0.015" rpy="0 0 0"/> <mass value="0.296"/> <inertia ixx="5.2e-05" iyy="5.2e-05" izz="5.9e-05" ixy="0.0" iyz="0.0" ixz="0.0"/> </inertial> <visual> <origin xyz="0 0 0" rpy="0 0 3.14159"/> <geometry> <mesh filename="file://$(find robo_desc)/meshes/extra.stl" scale="0.001 0.001 0.001"/> </geometry> <material name="grey"/> </visual> <collision> <origin xyz="0 0 0.0" rpy="0 0 0"/> <geometry> <mesh filename="file://$(find robo_desc)/meshes/extra.stl" scale="0.001 0.001 0.001"/> </geometry> </collision> </link> <joint name="sensors_joint" type="fixed"> <origin xyz="0 0 0" rpy="0 0 0"/> <parent link="base_link"/> <child link="part2"/> </joint>

<link name="lcd"> <inertial> <origin xyz="0 0 0.015" rpy="0 0 0"/> <mass value="0.050"/> <inertia ixx="1e-05" iyy="1e-05" izz="1e-05" ixy="0.0" iyz="0.0" ixz="0.0"/> </inertial> <visual> <origin xyz="0 0 0" rpy="0 0 3.14159"/> <geometry> <mesh filename="file://$(find robo_desc)/meshes/led.stl" scale="0.001 0.001 0.001"/> </geometry> <material name="white"/> </visual> <collision> <origin xyz="0 0 0" rpy="0 0 0"/> <geometry> <mesh filename="file://$(find robo_desc)/meshes/led.stl" scale="0.001 0.001 0.001"/> </geometry> </collision> </link> <joint name="display_joint" type="fixed"> <origin xyz="0 0 0" rpy="0 0 0"/> <parent link="base_link"/> <child link="lcd"/> </joint>

<link name="push_button"> <inertial> <origin xyz="0 0 0.0" rpy="0 0 0"/> <mass value="0.050"/> <inertia ixx="1e-05" iyy="1e-05" izz="1e-05" ixy="0.0" iyz="0.0" ixz="0.0"/> </inertial> <visual> <origin xyz="0 0 0" rpy="0 0 3.14159"/> <geometry> <mesh filename="file://$(find robo_desc)/meshes/switch.stl" scale="0.001 0.001 0.001"/> </geometry> <material name="red"/> </visual> <collision> <origin xyz="0 0 0" rpy="0 0 0"/> <geometry> <mesh filename="file://$(find robo_desc)/meshes/switch.stl" scale="0.001 0.001 0.001"/> </geometry> </collision> </link> <joint name="button_joint" type="fixed"> <origin xyz="0 0 0" rpy="0 0 0"/> <parent link="base_link"/> <child link="push_button"/> </joint>

<!-- ═══════════════════════════════════════════════════════════════════ LIDAR LINK ═══════════════════════════════════════════════════════════════════ -->

<link name="lidar"> <inertial> <origin xyz="0 0 0" rpy="0 0 0"/> <mass value="0.200"/> <inertia ixx="5.2e-05" iyy="5.2e-05" izz="5.9e-05" ixy="0.0" iyz="0.0" ixz="0.0"/> </inertial> <visual> <origin xyz="0.079 0.013 -0.133" rpy="0 0 3.14159"/> <geometry> <mesh filename="file://$(find robo_desc)/meshes/lidar.stl" scale="0.001 0.001 0.001"/> </geometry> <material name="grey"/> </visual> <collision> <origin xyz="0 0 -0.1" rpy="0 0 0"/> <geometry> <mesh filename="file://$(find robo_desc)/meshes/lidar.stl" scale="0.001 0.001 0.001"/> </geometry> </collision> </link> <joint name="lidar_joint" type="fixed"> <origin xyz="-0.079 0.0 0.133" rpy="0 0 0"/> <parent link="base_link"/> <child link="lidar"/> </joint>

<!-- ═══════════════════════════════════════════════════════════════════ IMU LINK ═══════════════════════════════════════════════════════════════════ -->

<link name="imu_link"> <inertial> <origin xyz="0 0 0" rpy="0 0 0"/> <mass value="0.010"/> <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0.0" iyz="0.0" ixz="0.0"/> </inertial> <visual> <origin xyz="0 0 0" rpy="0 0 0"/> <geometry><box size="0.02 0.02 0.01"/></geometry> <material name="red"/> </visual> <collision> <origin xyz="0 0 0" rpy="0 0 0"/> <geometry><box size="0.02 0.02 0.01"/></geometry> </collision> </link> <joint name="imu_joint" type="fixed"> <origin xyz="0 0 0.05" rpy="0 0 0"/> <parent link="base_link"/> <child link="imu_link"/> </joint>

<!-- ═══════════════════════════════════════════════════════════════════ GAZEBO PLUGINS ═══════════════════════════════════════════════════════════════════ -->

<!-- Mecanum Drive -->

<gazebo> <plugin filename="gz-sim-mecanum-drive-system" name="gz::sim::systems::MecanumDrive">

  <!-- Swapped order because robot is rotated 180 deg -->
  <front_left_joint>left_f</front_left_joint>
  <front_right_joint>right_f</front_right_joint>
  <back_left_joint>left_b</back_left_joint>
  <back_right_joint>right_b</back_right_joint>

  <!-- Geometry -->
  <wheel_separation>0.204108</wheel_separation>
  <wheelbase>0.151410</wheelbase>
  <wheel_radius>${wheel_radius}</wheel_radius>

  <!-- Topics -->
  <topic>cmd_vel</topic>
  <odom_topic>odom</odom_topic>
  <tf_topic>tf</tf_topic>

  <!-- Frames -->
  <frame_id>odom</frame_id>
  <child_frame_id>base_footprint</child_frame_id>

  <!-- Odom -->
  <odom_publish_frequency>50</odom_publish_frequency>
  <publish_odom>true</publish_odom>
  <publish_odom_tf>true</publish_odom_tf>
  <publish_wheel_tf>false</publish_wheel_tf>

  <!-- Velocity limits -->
  <min_velocity>-2.0</min_velocity>
  <max_velocity>2.0</max_velocity>
  <min_acceleration>-5.0</min_acceleration>
  <max_acceleration>5.0</max_acceleration>

</plugin>

</gazebo>

<!-- Joint State Publisher -->

<gazebo> <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"> <joint_name>right_f</joint_name> <joint_name>right_b</joint_name> <joint_name>left_f</joint_name> <joint_name>left_b</joint_name> <topic>joint_states</topic> <update_rate>50</update_rate> </plugin> </gazebo>

<!-- 2-D LiDAR -->

<gazebo reference="lidar"> <sensor name="gpu_lidar" type="gpu_lidar"> <pose>0 0 0 0 0 0</pose> <topic>scan</topic> <update_rate>10</update_rate> <ray> <scan> <horizontal> <samples>360</samples> <resolution>1</resolution> <min_angle>-3.14159265</min_angle> <max_angle> 3.14159265</max_angle> </horizontal> </scan> <range> <min>0.15</min> <max>12.0</max> <resolution>0.01</resolution> </range> <noise> <type>gaussian</type> <mean>0.0</mean> <stddev>0.01</stddev> </noise> </ray> <always_on>true</always_on> <visualize>true</visualize> <gz_frame_id>lidar</gz_frame_id> </sensor> </gazebo>

<!-- IMU -->

<gazebo reference="imu_link"> <sensor name="imu_sensor" type="imu"> <pose>0 0 0 0 0 0</pose> <topic>imu</topic> <update_rate>100</update_rate> <imu> <angular_velocity> <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev> <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></x> <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev> <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></y> <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev> <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></z> </angular_velocity> <linear_acceleration> <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev> <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></x> <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev> <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></y> <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev> <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></z> </linear_acceleration> </imu> <always_on>true</always_on> <gz_frame_id>imu_link</gz_frame_id> </sensor> </gazebo>

<!-- ═══════════════════════════════════════════════════════════════════ GAZEBO MATERIAL / VISUAL PROPERTIES (friction now lives inside <collision><surface> above — not here) ═══════════════════════════════════════════════════════════════════ -->

<gazebo reference="base_link"> <material>Gazebo/DarkGrey</material> </gazebo>
<gazebo reference="right_front"> <material>Gazebo/White</material> </gazebo>
<gazebo reference="right_back"> <material>Gazebo/White</material> </gazebo>
<gazebo reference="left_front"> <material>Gazebo/White</material> </gazebo>
<gazebo reference="left_back"> <material>Gazebo/White</material> </gazebo>
<gazebo reference="lidar"> <material>Gazebo/Grey</material> </gazebo>
<gazebo reference="imu_link"> <material>Gazebo/Red</material> </gazebo>
<gazebo reference="lcd"> <material>Gazebo/White</material> </gazebo>
<gazebo reference="push_button"> <material>Gazebo/Red</material> </gazebo>
<gazebo reference="part2"> <material>Gazebo/Grey</material> </gazebo>

</robot>
 <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
    <parent link="base_footprint"/>
    <child  link="base_link"/>
  </joint>

  <!-- ═══════════════ BASE LINK ═══════════════ -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.5"/>
      <inertia ixx="0.03311" iyy="0.019021" izz="0.0495"
               ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.20 0.18 0.08"/></geometry>
      <material name="blue"><color rgba="0 0.1 0.6 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.20 0.18 0.08"/></geometry>
    </collision>
  </link>

  <!-- ═══════════════ WHEEL MACRO ═══════════════
       Collision = SPHERE (gz-sim mecanum pattern)
       Friction set via <gazebo reference> block below
  ══════════════════════════════════════════════ -->
  <xacro:macro name="wheel" params="name jx jy fdir1_x fdir1_y">

    <link name="${name}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.789"/>
        <inertia ixx="0.000422" iyy="0.000761" izz="0.000422"
                 ixy="0" iyz="0" ixz="0"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="white"><color rgba="1 1 1 1"/></material>
      </visual>
      <!-- SPHERE for collision — required for gz-sim mecanum fdir1 to work -->
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${wheel_radius}"/></geometry>
      </collision>
    </link>

    <joint name="${name}_joint" type="continuous">
      <origin xyz="${jx} ${jy} 0" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child  link="${name}"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01" friction="0.0"/>
    </joint>

    <!-- Anisotropic friction — gz:expressed_in tells gz-sim the frame for fdir1 -->
    <gazebo reference="${name}">
      <material>Gazebo/White</material>
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>0.0</mu2>
              <fdir1 gz:expressed_in="base_footprint">${fdir1_x} ${fdir1_y} 0</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </gazebo>

  </xacro:macro>

  <!-- ═══════════════ WHEEL INSTANCES ═══════════════
       fdir1 encodes the 45° roller angle per wheel:
         front_left  / rear_right  →  1 -1  (rollers at -45°)
         front_right / rear_left   →  1  1  (rollers at +45°)
  ═════════════════════════════════════════════════ -->
  <xacro:wheel name="front_left"
    jx=" ${wheelbase/2}"  jy=" ${wheel_separation/2}"
    fdir1_x="1" fdir1_y="-1"/>

  <xacro:wheel name="front_right"
    jx=" ${wheelbase/2}"  jy="-${wheel_separation/2}"
    fdir1_x="1" fdir1_y="1"/>

  <xacro:wheel name="rear_left"
    jx="-${wheelbase/2}"  jy=" ${wheel_separation/2}"
    fdir1_x="1" fdir1_y="1"/>

  <xacro:wheel name="rear_right"
    jx="-${wheelbase/2}"  jy="-${wheel_separation/2}"
    fdir1_x="1" fdir1_y="-1"/>

  <!-- ═══════════════ LIDAR ═══════════════ -->
  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="5.2e-05" iyy="5.2e-05" izz="5.9e-05"
               ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="lidar_link"/>
  </joint>

  <!-- ═══════════════ IMU ═══════════════ -->
  <link name="imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6"
               ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <geometry><box size="0.02 0.02 0.01"/></geometry>
      <material name="red"><color rgba="0.8 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.02 0.02 0.01"/></geometry>
    </collision>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="imu_link"/>
  </joint>

  <!-- ═══════════════ GAZEBO PLUGINS ═══════════════ -->
  <gazebo>
    <plugin filename="gz-sim-mecanum-drive-system"
            name="gz::sim::systems::MecanumDrive">
      <front_left_joint>front_left_joint</front_left_joint>
      <front_right_joint>front_right_joint</front_right_joint>
      <back_left_joint>rear_left_joint</back_left_joint>
      <back_right_joint>rear_right_joint</back_right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheelbase>${wheelbase}</wheelbase>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <min_velocity>-2.0</min_velocity>
      <max_velocity>2.0</max_velocity>
      <min_acceleration>-5.0</min_acceleration>
      <max_acceleration>5.0</max_acceleration>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>front_left_joint</joint_name>
      <joint_name>front_right_joint</joint_name>
      <joint_name>rear_left_joint</joint_name>
      <joint_name>rear_right_joint</joint_name>
      <topic>joint_states</topic>
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>

  <!-- 2-D LiDAR sensor -->
  <gazebo reference="lidar_link">
    <material>Gazebo/Grey</material>
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle> 3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <gz_frame_id>lidar_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- IMU sensor -->
  <gazebo reference="imu_link">
    <material>Gazebo/Red</material>
    <sensor name="imu_sensor" type="imu">
      <pose>0 0 0 0 0 0</pose>
      <topic>imu</topic>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></noise></z>
        </linear_acceleration>
      </imu>
      <always_on>true</always_on>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <gazebo reference="base_link"><material>Gazebo/Blue</material></gazebo>

</robot>
